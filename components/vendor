<!-- FILE BARU: components/vendor.html -->
<!-- Modal Vendor Management -->
<div class="modal fade" id="vendorModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content rounded-4">
      <div class="modal-header border-0 bg-gradient bg-primary text-white py-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-shop me-2"></i><span id="vendorModalTitle">Tambah Vendor</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <input type="hidden" id="vendorEditId">
        
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Nama Vendor <span class="text-danger">*</span></label>
            <input type="text" id="vendorName" class="form-control" placeholder="Contoh: MUA Sarah">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Kategori</label>
            <select id="vendorCategory" class="form-select">
              <option value="MUA">💄 MUA & Makeup</option>
              <option value="Photography">📸 Photography & Videography</option>
              <option value="Catering">🍽️ Catering</option>
              <option value="Venue">🏨 Venue / Gedung</option>
              <option value="Decoration">💐 Dekorasi</option>
              <option value="Entertainment">🎤 Entertainment & MC</option>
              <option value="Busana">👗 Busana Pengantin</option>
              <option value="Cincin">💍 Cincin & Perhiasan</option>
              <option value="Transport">🚗 Transportasi</option>
              <option value="Other">📦 Lainnya</option>
            </select>
          </div>
        </div>
        
        <div class="row g-3 mt-1">
          <div class="col-md-6">
            <label class="form-label fw-semibold">📞 Kontak (HP/Telp)</label>
            <input type="tel" id="vendorContact" class="form-control" placeholder="0812-3456-7890">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">📍 Alamat / Link Maps</label>
            <input type="text" id="vendorAddress" class="form-control" placeholder="Alamat atau link Google Maps">
          </div>
        </div>
        
        <div class="row g-3 mt-1">
          <div class="col-md-4">
            <label class="form-label fw-semibold">💰 Estimasi Harga</label>
            <div class="input-group">
              <span class="input-group-text">Rp</span>
              <input type="text" id="vendorEstimatedPrice" class="form-control" placeholder="0" inputmode="numeric">
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">💵 Harga Deal</label>
            <div class="input-group">
              <span class="input-group-text">Rp</span>
              <input type="text" id="vendorDealPrice" class="form-control" placeholder="0" inputmode="numeric">
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold">⭐ Rating</label>
            <select id="vendorRating" class="form-select">
              <option value="5">★★★★★ (5) - Luar biasa</option>
              <option value="4">★★★★☆ (4) - Baik</option>
              <option value="3">★★★☆☆ (3) - Cukup</option>
              <option value="2">★★☆☆☆ (2) - Kurang</option>
              <option value="1">★☆☆☆☆ (1) - Buruk</option>
            </select>
          </div>
        </div>
        
        <div class="mt-3">
          <label class="form-label fw-semibold">📝 Catatan</label>
          <textarea id="vendorNotes" class="form-control" rows="2" placeholder="Catatan penting tentang vendor ini..."></textarea>
        </div>
        
        <div class="form-check mt-3">
          <input type="checkbox" id="vendorIsBooked" class="form-check-input">
          <label class="form-check-label">✅ Sudah booking / DP</label>
        </div>
      </div>
      <div class="modal-footer border-0 pt-0 pb-4">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Batal</button>
        <button type="button" onclick="window.saveVendor()" class="btn btn-primary rounded-pill px-4">
          <i class="bi bi-save me-2"></i>Simpan Vendor
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Vendor Detail -->
<div class="modal fade" id="vendorDetailModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-md">
    <div class="modal-content rounded-4">
      <div class="modal-header border-0 bg-gradient bg-info text-white py-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-shop me-2"></i><span id="vendorDetailName"></span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-tag"></i> Kategori</span>
            <span class="fw-semibold" id="vendorDetailCategory"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-telephone"></i> Kontak</span>
            <span class="fw-semibold" id="vendorDetailContact"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-geo-alt"></i> Alamat</span>
            <span class="fw-semibold" id="vendorDetailAddress"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-cash-stack"></i> Estimasi</span>
            <span class="fw-semibold text-primary" id="vendorDetailEstimated"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-check-circle"></i> Harga Deal</span>
            <span class="fw-semibold text-success" id="vendorDetailDeal"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-star-fill text-warning"></i> Rating</span>
            <span class="fw-semibold" id="vendorDetailRating"></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted"><i class="bi bi-calendar-check"></i> Status</span>
            <span class="badge" id="vendorDetailStatus"></span>
          </div>
        </div>
        <hr>
        <div class="mt-2">
          <label class="fw-semibold small text-muted">📝 Catatan</label>
          <p id="vendorDetailNotes" class="mb-0 mt-1" style="white-space: pre-wrap;"></p>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button class="btn btn-danger rounded-pill" onclick="window.deleteVendorFromDetail()">Hapus</button>
        <button class="btn btn-primary rounded-pill" onclick="window.editVendorFromDetail()">Edit</button>
        <button class="btn btn-success rounded-pill" onclick="window.copyVendorContact()">
          <i class="bi bi-copy me-1"></i>Salin Kontak
        </button>
      </div>
    </div>
  </div>
</div>
